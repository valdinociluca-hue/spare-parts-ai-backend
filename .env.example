# ─────────────────────────────────────────────────────────────
#  spare-parts-ai-backend — Environment Variables
#  Copy to .env and fill in real values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────
APP_NAME=spare-parts-ai-backend
APP_VERSION=0.1.0
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=spare_parts
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/spare_parts

# ── LLM Provider ──────────────────────────────────────────────
# "yandex" for production (Russia), "ollama" for local dev
LLM_PROVIDER=yandex

# ── YandexGPT (production) ────────────────────────────────────
# 1. Go to console.yandex.cloud
# 2. Create a service account with role ai.languageModels.user
# 3. Create an API key for the service account
# 4. Copy your Folder ID from the cloud console (top-left)
YANDEX_API_KEY=your_yandex_api_key_here
YANDEX_FOLDER_ID=your_yandex_folder_id_here
YANDEX_GPT_MODEL=yandexgpt        # yandexgpt (Pro) | yandexgpt-lite (fast)
YANDEX_API_BASE=https://llm.api.cloud.yandex.net

# ── Ollama (local development / fallback) ─────────────────────
# Install: https://ollama.com  then: ollama pull qwen2.5:14b
OLLAMA_API_BASE=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:14b

# ── Shared LLM settings ───────────────────────────────────────
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1500
LLM_TIMEOUT=45.0

# ── VK Teams Bot ──────────────────────────────────────────────
VK_TEAMS_BOT_TOKEN=your_token_here
VK_TEAMS_CHAT_ID=your_internal_chat_id
VK_TEAMS_API_BASE=https://api.internal.myteam.mail.ru/bot/v1

# ── Bitrix ────────────────────────────────────────────────────
BITRIX_WEBHOOK_SECRET=

# ── Processing ────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.6
DRAFT_ONLY_MODE=true
