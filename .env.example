# ─────────────────────────────────────────────────────────────
#  PartsAI — Environment Variables
#  Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────

# ── Application ──
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO
APP_SECRET_KEY=replace-me-in-prod
JWT_SECRET=replace-me-in-prod

# ── Database ──
# Local dev: docker-compose Postgres on :54322 (see docker-compose.yml)
# Prod: Supabase pooled connection string
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:54322/postgres

# ── Supabase (managed) ──
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Pinecone (vector DB) ──
PINECONE_API_KEY=
PINECONE_INDEX=partsai-products
PINECONE_ENVIRONMENT=us-east-1

# ── LLM providers (per-tenant routing in apps/api/app/llm/router.py) ──
# YandexGPT for tenants with region='RU'
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_GPT_MODEL=yandexgpt
YANDEX_API_BASE=https://llm.api.cloud.yandex.net

# Claude for tenants with region='GLOBAL'
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Embeddings (used for both regions; cheap + good) ──
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Frontend (NEXT_PUBLIC_ vars are exposed to the browser) ──
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WIDGET_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_DOMAIN=partsai.local
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=lvtrade

# ── Stripe (skeleton, not wired in Phase 1) ──
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# ── Shared LLM tuning ──
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1500
LLM_TIMEOUT=45.0
